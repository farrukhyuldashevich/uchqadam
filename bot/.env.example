# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:ABCDEF_your_bot_token_here

# Telegram chat ID of the private ops group (negative integer for groups, e.g. -1001234567890)
# How to get it: add the bot to the group, send any message, then check the bot logs OR
# use the @userinfobot in the group to read the chat ID.
OPS_GROUP_ID=-1001234567890

# Optional: comma-separated Telegram user IDs of merchants who can press order-control buttons.
# Leave empty during development to allow anyone in the ops group to control orders.
MERCHANT_IDS=

# Optional: store display name shown to customers
STORE_NAME=Emir Market

# Path to the SQLite database file (relative to bot/ dir)
DB_PATH=uchqadam.db

# Delivery fee added to every order's bill (in sum, integer)
DELIVERY_FEE=5000

# Bank-card details shown to customers who pick "Transfer" at payment time.
# Leave both blank if you only want to accept cash for now.
TRANSFER_CARD=8600 1234 5678 9012
TRANSFER_HOLDER=Emir M.
